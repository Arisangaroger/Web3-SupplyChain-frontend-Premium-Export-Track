# Browser-facing API base. Use /api to proxy through Next.js (recommended for local dev).
NEXT_PUBLIC_API_URL=/api

# Next.js server-side proxy target (not exposed to the browser)
BACKEND_URL=http://localhost:3000

# Optional: block explorer base URL for on-chain proof links (defaults to Polygon Amoy)
# NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://amoy.polygonscan.com
